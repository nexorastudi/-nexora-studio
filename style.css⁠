:root {
    /* Color Palette */
    --c-black: #050505;
    --c-white: #ffffff;
    --c-blue: #2563EB;
    --c-blue-hover: #1d4ed8;
    --c-gray-dark: #1a1a1a;
    --c-gray-light: #888888;
    --c-glass: rgba(255, 255, 255, 0.03);
    --c-glass-border: rgba(255, 255, 255, 0.08);
    
    /* Typography */
    --font-heading: 'Sora', sans-serif;
    --font-body: 'Manrope', sans-serif;
    
    /* Spacing & Layout */
    --container-max: 1200px;
    --section-pad: 120px 20px;
    
    /* Transitions */
    --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Reset & Base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    background-color: var(--c-black);
    color: var(--c-white);
    font-family: var(--font-body);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
}

img {
    max-width: 100%;
    display: block;
}

a {
    color: inherit;
    text-decoration: none;
    transition: var(--transition-smooth);
}

/* Typography */
h1, h2, h3, h4 {
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.2;
}

.text-gradient {
    background: linear-gradient(135deg, var(--c-white) 0%, var(--c-blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.section-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
}

.text-center {
    text-align: center;
}

/* Utilities */
.container {
    max-width: var(--container-max);
    margin: 0 auto;
    width: 100%;
}

.section {
    padding: var(--section-pad);
}

.bg-elevated {
    background: linear-gradient(to bottom, #0a0a0a, var(--c-black));
}

.w-100 {
    width: 100%;
}

/* Buttons */
.btn-primary {
    display: inline-block;
    background: var(--c-white);
    color: var(--c-black);
    padding: 14px 28px;
    border-radius: 100px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    border: 1px solid var(--c-white);
    cursor: pointer;
    text-align: center;
}

.btn-primary:hover {
    background: transparent;
    color: var(--c-white);
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
}

/* Navigation */
.navbar {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    background: rgba(5, 5, 5, 0.7);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--c-glass-border);
    padding: 1.2rem 20px;
}

.nav-container {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
}

.logo span {
    color: var(--c-blue);
}

.nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
}

.nav-links a:not(.btn-primary) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--c-gray-light);
}

.nav-links a:not(.btn-primary):hover {
    color: var(--c-white);
}

/* Hero Section */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 150px 20px 80px;
    overflow: hidden;
}

.ambient-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.15) 0%, rgba(5, 5, 5, 0) 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
    pointer-events: none;
}

.hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
}

.badge {
    display: inline-block;
    padding: 6px 16px;
    background: var(--c-glass);
    border: 1px solid var(--c-glass-border);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--c-gray-light);
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    margin-bottom: 1.5rem;
    letter-spacing: -0.04em;
}

.hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--c-gray-light);
    max-width: 600px;
    margin: 0 auto 3rem;
}

/* About Section */
.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
}

.about-text p {
    color: var(--c-gray-light);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
}

.glass-panel {
    background: var(--c-glass);
    border: 1px solid var(--c-glass-border);
    padding: 4rem 3rem;
    border-radius: 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
}

.glass-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--c-blue), transparent);
}

.glass-panel h3 {
    font-size: 2rem;
    margin-bottom: 1rem;
}

.glass-panel p {
    color: var(--c-gray-light);
}

/* Services Section */
.services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
}

.service-card {
    background: var(--c-gray-dark);
    border: 1px solid var(--c-glass-border);
    padding: 2.5rem;
    border-radius: 16px;
    transition: var(--transition-smooth);
}

.service-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
}

.service-card .icon {
    font-size: 2rem;
    color: var(--c-blue);
    margin-bottom: 1.5rem;
}

.service-card h3 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
}

.service-card p {
    color: var(--c-gray-light);
    font-size: 0.95rem;
}

/* Portfolio Section */
.portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
}

.case-study {
    group: case;
    cursor: pointer;
}

.case-image {
    width: 100%;
    height: 400px;
    background-color: var(--c-gray-dark);
    border-radius: 16px;
    margin-bottom: 1.5rem;
    transition: var(--transition-smooth);
    position: relative;
    overflow: hidden;
}

/* Simulated Image Backgrounds */
.case-image.lumina { background: linear-gradient(45deg, #1a1a1a, #2a2a2a); }
.case-image.afridata { background: linear-gradient(45deg, #0f172a, #1e293b); }
.case-image.horizon { background: linear-gradient(45deg, #18181b, #27272a); }

.case-study:hover .case-image {
    transform: scale(0.98);
}

.case-category {
    font-size: 0.8rem;
    color: var(--c-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
}

.case-info h3 {
    font-size: 1.6rem;
    margin: 0.5rem 0;
}

.case-info p {
    color: var(--c-gray-light);
    font-size: 0.95rem;
}

/* Contact Section */
.contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    background: var(--c-gray-dark);
    border: 1px solid var(--c-glass-border);
    border-radius: 24px;
    padding: 4rem;
}

.contact-desc {
    color: var(--c-gray-light);
    font-size: 1.1rem;
    margin-bottom: 3rem;
}

.contact-method {
    margin-bottom: 1.5rem;
}

.method-label {
    display: block;
    font-size: 0.85rem;
    color: var(--c-gray-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
}

.method-value {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--c-white);
}

.method-value[href]:hover {
    color: var(--c-blue);
}

.contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.input-group label {
    display: block;
    font-size: 0.9rem;
    color: var(--c-gray-light);
    margin-bottom: 0.5rem;
}

.input-group input,
.input-group textarea {
    width: 100%;
    background: var(--c-black);
    border: 1px solid var(--c-glass-border);
    padding: 1rem;
    border-radius: 8px;
    color: var(--c-white);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: var(--transition-smooth);
}

.input-group input:focus,
.input-group textarea:focus {
    outline: none;
    border-color: var(--c-blue);
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2);
}

/* Footer & Marquee */
.footer {
    border-top: 1px solid var(--c-glass-border);
    background: var(--c-black);
}

.marquee-container {
    width: 100%;
    overflow: hidden;
    padding: 2rem 0;
    border-bottom: 1px solid var(--c-glass-border);
    background: var(--c-gray-dark);
}

.marquee-content {
    display: inline-flex;
    white-space: nowrap;
    animation: marquee 20s linear infinite;
    gap: 3rem;
    align-items: center;
}

.marquee-content span {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--c-gray-light);
}

@keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 1.5rem)); }
}

.footer-bottom {
    padding: 2rem 20px;
}

.flex-between {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--c-gray-light);
    font-size: 0.9rem;
}

.footer-links {
    display: flex;
    gap: 1.5rem;
}

.footer-links a:hover {
    color: var(--c-white);
}

/* Animations */
.reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.reveal.active {
    opacity: 1;
    transform: translateY(0);
}

/* Media Queries */
@media (max-width: 992px) {
    .about-grid, .contact-wrapper {
        grid-template-columns: 1fr;
    }
    
    .nav-links {
        display: none; /* In production, add a hamburger menu */
    }
}

@media (max-width: 768px) {
    .section {
        padding: 80px 20px;
    }
    
    .contact-wrapper {
        padding: 2rem;
    }
    
    .flex-between {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
    }
}
