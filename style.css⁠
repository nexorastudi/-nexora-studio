/* Variables de Charte Graphique */
:root {
    --black: #000000;
    --dark-gray: #111111;
    --card-bg: #1F2937;
    --blue: #2563EB;
    --white: #FFFFFF;
    --font-heading: 'Sora', sans-serif;
    --font-body: 'Manrope', sans-serif;
}

/* Reset & Base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    line-height: 1.6;
    scroll-behavior: smooth;
    overflow-x: hidden;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

.text-center { text-align: center; }
.text-blue { color: var(--blue); }
.section-padding { padding: 100px 0; }
.section-subtitle { color: var(--blue); font-weight: 700; letter-spacing: 3px; font-size: 0.8rem; text-transform: uppercase; }

/* Navbar */
.navbar {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    padding: 20px 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: 0.3s;
}

.nav-container {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 30px;
}

.nav-logo { font-family: var(--font-heading); font-weight: 800; font-size: 1.4rem; }
.logo-blue { color: var(--blue); }

.nav-links { display: flex; list-style: none; }
.nav-links li { margin: 0 20px; }
.nav-links a { color: var(--white); text-decoration: none; font-size: 0.9rem; transition: 0.3s; }
.nav-links a:hover { color: var(--blue); }

.nav-right { display: flex; align-items: center; }
.social-btns a { color: var(--white); margin: 0 10px; font-size: 1.1rem; transition: 0.3s; }
.social-btns a:hover { color: var(--blue); }

.btn-contact-nav {
    background: var(--blue);
    color: white;
    padding: 8px 20px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    margin-left: 20px;
}

/* Hero */
.hero {
    height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at center, #1e293b 0%, var(--black) 70%);
    text-align: center;
    padding: 0 20px;
}

.hero-logo-box { margin-bottom: 30px; animation: fadeIn 1.5s; }
.hero h1 { font-family: var(--font-heading); font-size: 4rem; font-weight: 800; margin-bottom: 5px; }
.hero-tagline { font-family: var(--font-body); letter-spacing: 5px; font-size: 0.9rem; color: rgba(255,255,255,0.6); }
.hero-divider { width: 60px; height: 3px; background: var(--blue); margin: 30px auto; }
.hero-main-text { font-family: var(--font-heading); font-size: 2rem; max-width: 800px; line-height: 1.2; }

/* About Grid */
.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
}

.about-info h2 { font-family: var(--font-heading); font-size: 2.5rem; margin: 15px 0 25px; }
.about-info p { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: 20px; }

.vision-box {
    background: var(--dark-gray);
    padding: 40px;
    border-radius: 12px;
    border-left: 4px solid var(--blue);
}

.vision-box h3 { font-family: var(--font-heading); margin-bottom: 20px; }
.values { display: flex; flex-direction: column; gap: 10px; margin-top: 20px; }
.values span { color: var(--blue); font-weight: 600; font-size: 0.9rem; }

/* Expertise Cards */
.expertise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-top: 60px;
}

.expertise-card {
    background: var(--card-bg);
    padding: 40px 30px;
    border-radius: 8px;
    transition: 0.3s;
    border: 1px solid rgba(255,255,255,0.05);
}

.expertise-card:hover { transform: translateY(-10px); border-color: var(--blue); }
.card-icon { font-size: 2.5rem; color: var(--blue); margin-bottom: 20px; }
.expertise-card h3 { font-family: var(--font-heading); margin-bottom: 15px; }
.expertise-card p { font-size: 0.9rem; color: rgba(255,255,255,0.6); }

/* Portfolio */
.portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
}

.portfolio-item {
    position: relative;
    height: 400px;
    overflow: hidden;
    border-radius: 10px;
}

.portfolio-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: 0.5s;
}

.portfolio-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 30px;
    background: linear-gradient(to top, black, transparent);
    transform: translateY(20px);
    transition: 0.4s;
    opacity: 0;
}

.portfolio-item:hover img { transform: scale(1.1); }
.portfolio-item:hover .portfolio-overlay { opacity: 1; transform: translateY(0); }

.proj-cat { font-size: 0.7rem; color: var(--blue); font-weight: 800; letter-spacing: 2px; }
.portfolio-overlay h4 { font-family: var(--font-heading); font-size: 1.5rem; }

/* Footer & Ribbon */
.footer { padding-top: 100px; background: var(--black); }
.footer h2 { font-family: var(--font-heading); font-size: 2.5rem; margin-bottom: 20px; }
.footer-phone { font-size: 3rem; font-weight: 800; color: white; text-decoration: none; display: block; margin-bottom: 20px; transition: 0.3s; }
.footer-phone:hover { color: var(--blue); }

.ribbon {
    background: #000;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 25px 0;
    margin-top: 80px;
    overflow: hidden;
    white-space: nowrap;
}

.ribbon-track {
    display: inline-block;
    animation: scrollRibbon 20s linear infinite;
}

.ribbon span {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.4);
    padding: 0 40px;
}

@keyframes scrollRibbon {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Mobile Responsive */
@media (max-width: 768px) {
    .nav-links, .social-btns { display: none; }
    .hero h1 { font-size: 2.5rem; }
    .about-grid, .portfolio-grid { grid-template-columns: 1fr; }
    .footer-phone { font-size: 1.8rem; }
}