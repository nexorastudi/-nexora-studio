/* Custom Global Refinement Styles */

:root {
    --brand-primary: #2563EB;
    --brand-bg: #111111;
    --brand-surface: #1F2937;
    --brand-text: #F5F5F5;
    --brand-accent: #60A5FA;
}

/* Custom Selection Highlight */
::selection {
    background-color: var(--brand-primary);
    color: white;
}

/* Base resets & Fonts mapping overrides */
h1, h2, h3, h4 {
    font-family: 'Sora', sans-serif;
}

/* Smooth Scrolling performance tweak */
@media (prefers-reduced-motion: no-preference) {
    html {
        scroll-behavior: smooth;
    }
}

/* Premium Glassmorphism Configuration */
.glass-card {
    background: rgba(31, 41, 55, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease;
}

.glass-card:hover {
    border-color: rgba(96, 165, 250, 0.2);
}

/* Nav Blur Interaction state */
.nav-blur {
    background: rgba(17, 17, 17, 0.75) !important;
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

/* Keyframe Animations definition */
@keyframes loadingBar {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
}

.animate-loading-bar {
    animation: loadingBar 1.5s infinite ease-in-out;
}

@keyframes float {
    0%, 100% { transform: translate(-50%, -50%) translateY(0px); }
    50% { transform: translate(-50%, -50%) translateY(-20px); }
}

.animate-float {
    animation: float 8s infinite ease-in-out;
}

/* Reveal on scroll styling baseline setup */
.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
}

.reveal.active {
    opacity: 1;
    transform: translateY(0);
}

/* Interactive Component Filtering layout logic */
.portfolio-item {
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
.portfolio-item.hidden-item {
    opacity: 0;
    transform: scale(0.9) translateY(20px);
    pointer-events: none;
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
}

/* Active Filtering Button */
.filter-btn.active {
    color: #ffffff;
    border-bottom: 2px solid var(--brand-accent);
}

/* Custom Form element optimizations */
input, select, textarea {
    will-change: border-color;
}